{
	"name": "vite-listening-to",
	"version": "0.1.0",
	"description": "Vite build plugin to fetch last listened to song from lastfm.",
	"type": "module",
	"author": "cod3ddot@proton.me",
	"license": "MIT",
	"files": [
		"dist"
	],
	"scripts": {
		"prepare": "bunup",
		"build": "bunup",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"lint": "bunx biome check --write"
	},
	"keywords": [
		"vite",
		"lastfm",
		"music"
	],
	"dependencies": {
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"vite": "^8.0.2",
		"typescript": "latest"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@commitlint/types": "^20.5.0",
		"@types/bun": "^1.3.11",
		"bunup": "^0.16.31"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
